@baseUrl = http://localhost:3001
@apiUrl = {{baseUrl}}/api
@json = application/json

# Set this value manually after creating a product
@productId = 22222222-2222-2222-2222-222222222222

### Create product
POST {{apiUrl}}/products
Content-Type: {{json}}

{
  "name": "Autumn Tart",
  "price": 8.5,
  "description": "Seasonal tart with apple and cinnamon",
  "allergens": "gluten,nuts"
}

###

### Get all products
GET {{apiUrl}}/products

### Get product by id
GET {{apiUrl}}/products/17e3c918-c4b4-4a0a-9167-ee061c4e3eba

###

### Patch product
PATCH {{apiUrl}}/products/{{productId}}
Content-Type: {{json}}

{
  "name": "Autumn Tart Deluxe",
  "price": 9.9
}

###

### Delete product
DELETE {{apiUrl}}/products/{{productId}}

